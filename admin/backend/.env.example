# Point at the same database the duratiq engine writes to.
DATABASE_URL=sqlite:///./duratiq.db
# Single shared admin token. Leave empty to disable auth (local dev only).
ADMIN_TOKEN=change-me-please
# Comma-separated allowed CORS origins (the frontend dev server).
CORS_ORIGINS=http://localhost:5173
# Broker the duratiq workers consume (redis://… or amqp://…). Required for the
# Retry action; leave empty to disable retry (it returns 503).
DURATIQ_BROKER_URL=
# Queue the duratiq_tick actor listens on (matches DramatiqDriver's default).
DURATIQ_BROKER_QUEUE=duratiq
